generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id         String   @id @default(cuid())
  userId     String?
  total      Float
  status     String   @default("PENDING")
  items      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
